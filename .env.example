# Optional: password auth for dashboards exposed beyond trusted local networks
# OCEAN_BLUE_AUTH_PASSWORD=change-me
# OCEAN_BLUE_SESSION_SECRET=replace-with-a-long-random-string

# Optional: explicitly force open mode for trusted local environments only
# OCEAN_BLUE_ALLOW_INSECURE_NO_AUTH=true

# Base URL for the server
BASE_URL=http://localhost:25830

# Server port
PORT=25830

# Database URL (SQLite)
DATABASE_URL=file:../../../data/dev.db

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Optional: tunnel proxy hardening
# TUNNEL_PROXY_BODY_LIMIT=10mb
# TUNNEL_PROXY_RATE_LIMIT_WINDOW_MS=60000
# TUNNEL_PROXY_RATE_LIMIT_MAX=600

# Node environment: development, production
NODE_ENV=development
